      ]
    },
    {
      "id": 12,
      "name": "Data Center Tier Avançado",
      "difficulty": "hard",
      "inventory": [
        { "id": "isp1", "type": "telecom", "ports": ["out"] },
        { "id": "isp2", "type": "telecom", "ports": ["out"] },
        { "id": "firewall", "type": "security", "ports": ["wan1", "wan2", "lan"] },
        { "id": "core_switch", "type": "network", "ports": ["uplink", "lan1", "lan2", "lan3"] },
        { "id": "server_cluster", "type": "compute", "ports": ["eth0", "eth1"] }
