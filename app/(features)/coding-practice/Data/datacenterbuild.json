        { "from": "switch2.lan1", "to": "server.eth1", "cable": "cat6" }
      ],
      "rules": [
        "O servidor deve permanecer online mesmo se um dos switches falhar",
        "As conexões físicas devem ser redundantes"
      ]
    },
    {
      "id": 10,
