        { "from": "firewall.lan", "to": "core_switch.uplink", "cable": "fiber" },
        { "from": "core_switch.lan1", "to": "server_cluster.eth0", "cable": "cat6a" },
        { "from": "core_switch.lan2", "to": "server_cluster.eth1", "cable": "cat6a" }
