      ]
    },

    {
      "id": 7,
      "name": "Segmentação com VLAN",
      "difficulty": "medium",
      "inventory": [
        { "id": "router", "type": "network", "ports": ["wan_in", "lan_out"] },
        { "id": "switch_managed", "type": "network", "ports": ["uplink", "lan1", "lan2", "lan3", "lan4"] },
