      "connections_required": [
        { "from": "switch_core.uplink1", "to": "server.eth0", "cable": "cat6a" },
        { "from": "switch_core.uplink2", "to": "server.eth1", "cable": "cat6a" }
      ],
      "rules": [
        "Ambos os links físicos devem estar ativos",
        "A agregação (LACP) é necessária para atingir a largura de banda total"
      ]
    },
    {
      "id": 9,
      "name": "Alta disponibilidade com 2 switches",
      "difficulty": "hard",
      "inventory": [
        { "id": "switch1", "type": "network", "ports": ["uplink", "lan1", "lan2"] },
        { "id": "switch2", "type": "network", "ports": ["uplink", "lan1", "lan2"] },
